# ================================
#  Emanus — variabile de mediu
#  Copiază în `.env` (rădăcina repo-ului). NU comite `.env` (e în .gitignore).
# ================================

# ---- API ----
PORT=3000
NODE_ENV=development

# ---- Supabase / Postgres (Prisma) ----
# Din Supabase dashboard: Project Settings -> Database -> Connection string.
#
# DATABASE_URL = conexiune "pooled" (Transaction, port 6543) — pentru runtime-ul aplicației.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PAROLA-DB]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# DIRECT_URL = conexiune directă (port 5432) — folosită de Prisma la migrări/introspecție.
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PAROLA-DB]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ---- Supabase API (pentru Auth & Storage în fazele următoare) ----
# Din Supabase dashboard: Project Settings -> API.
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="..."           # public (safe pentru client)
SUPABASE_SERVICE_ROLE_KEY="..."   # SECRET — doar pe server, niciodată în client

# ---- Auth propriu (doar dacă NU folosim Supabase Auth) ----
JWT_SECRET="change-me"
